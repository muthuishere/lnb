<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>lnb</id>
    <version>0.1.0</version>
    <title>LNB</title>
    <authors>muthuishere</authors>
    <projectUrl>https://github.com/muthuishere/lnb</projectUrl>
    <tags>lnb cli utility cross-platform</tags>
    <summary>Link Binary - A cross-platform utility to link binaries to your PATH</summary>
    <description>LNB makes command-line tools accessible from anywhere by creating symbolic links or wrapper scripts in your system's PATH. It works across Linux, macOS, and Windows with a consistent interface. Features include cross-platform compatibility and a simple interface with just install and remove commands.</description>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
  </files>
</package>
